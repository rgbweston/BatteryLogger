<?xml version="1.0"?>
<!--
  properties.xml defines settings that appear in the Garmin Connect mobile app
  under the app's Settings page.  Note: sideloaded apps do NOT appear in Garmin Connect settings,
  so these defaults can only be changed by rebuilding with new values here.

  Exposed settings:
    interval_sec   — logging interval (300–3600 s). Default 300 (5 min).
    sync_endpoint  — the POST URL for battery readings.
-->
<properties>
  <property id="interval_sec" type="Number">300</property>
  <property id="sync_endpoint" type="String">https://batterylogger.onrender.com/api/battery-readings</property>
</properties>
